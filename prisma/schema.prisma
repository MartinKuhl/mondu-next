generator client {
    provider = "prisma-client"
    output   = "../src/generated/prisma"
}

datasource db {
    provider = "postgresql"
}

model Webhooks {
    id                    Int      @id @default(autoincrement())
    createdAt             DateTime @default(now())
    external_reference_id String?
    topic                 String
    order_uuid            String?
    order_state           String?
    event_time            DateTime? @default(now())
    payload               String
}
